# 개발 환경용 환경 변수 파일
# docker-compose.dev.yml 에서 사용

# =============================================================================
# 데이터베이스 설정
# =============================================================================
POSTGRES_PASSWORD=changethis
POSTGRES_USER=postgres
POSTGRES_DB=app

# =============================================================================
# 백엔드 설정
# =============================================================================
# 도메인 (로컬 개발)
DOMAIN=localhost
FRONTEND_HOST=http://localhost:5173
ENVIRONMENT=local

# CORS 허용 출처 (쉼표로 구분)
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:8000

# JWT 시크릿 키 (개발용 - 프로덕션에서는 반드시 변경!)
SECRET_KEY=changethis-secret-key-for-dev-only

# =============================================================================
# 첫 번째 슈퍼유저 (관리자)
# =============================================================================
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=changethis

# =============================================================================
# 모니터링 (선택사항)
# =============================================================================
SENTRY_DSN=

# =============================================================================
# 개발 팁
# =============================================================================
# 1. 이 파일은 git에 커밋하지 마세요 (.gitignore에 추가)
# 2. 비밀번호는 간단하게 설정해도 됩니다 (로컬 개발용)
# 3. 파일 수정 후 재시작: docker compose -f docker-compose.dev.yml restart
# 4. 이메일 기능(비밀번호 복구)은 제거되었습니다
